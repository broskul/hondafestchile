PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# URL publica del bucket R2 para imagenes estaticas.
# Ejemplo: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
# Si queda vacio, /media usa la copia local en desarrollo o las credenciales S3 como respaldo.
R2_PUBLIC_BASE_URL=

# Supabase como base de datos de ticketera.
SUPABASE_URL=https://jvmibnyiinzpkahbkyec.supabase.co
# Conexion server-side directa a Postgres/Supabase Pooler. Recomendado para produccion.
SUPABASE_DB_URL=
# Opcional: usa este nombre si SUPABASE_URL queda reservado para otra integracion.
SUPABASE_REST_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://jvmibnyiinzpkahbkyec.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backoffice oculto. Define un token largo para produccion.
BACKOFFICE_TOKEN=

# Portal privado de enrolamiento post-pago.
# Si ENROLLMENT_PORTAL_PASSWORD queda vacio, usa BACKOFFICE_PASSWORD/BACKOFFICE_TOKEN como respaldo.
ENROLLMENT_PORTAL_USER=admin
ENROLLMENT_PORTAL_PASSWORD=

# SMTP para confirmacion de correo, tickets y boleta.
# Si queda vacio, la app opera en modo demo y escribe los correos en consola.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Honda Fest Chile <tickets@hondafestchile.cl>"

# Microsoft Graph para envio de correos con Entra ID / Microsoft 365.
# Si MS_* esta completo, la app usa Graph antes que SMTP. Requiere permiso Application Mail.Send con admin consent.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Opcional: si queda vacio se usa SMTP_USER o el correo dentro de SMTP_FROM.
MS_SENDER_EMAIL=
MS_SAVE_TO_SENT_ITEMS=true

# Mercado Pago Checkout API interno.
# Con token vacio, la ticketera genera una orden local y permite simular pago.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_INTERNAL_CHECKOUT=true
# Opcional: si lo dejas vacio se usa PUBLIC_BASE_URL + /api/webhooks/mercadopago.
MERCADOPAGO_NOTIFICATION_URL=
# Opcionales para pruebas/produccion.
MERCADOPAGO_USE_SANDBOX=false
MERCADOPAGO_BINARY_MODE=false
MERCADOPAGO_STATEMENT_DESCRIPTOR="HONDA FEST"
MERCADOPAGO_STORE_RAW_PAYLOADS=false
# En Vercel no se permite vender con JSON temporal salvo que lo fuerces explicitamente.
ALLOW_VOLATILE_CHECKOUT=false

# OpenFactura / Haulmer.
# El endpoint exacto y payload pueden variar segun contrato/cuenta API.
OPENFACTURA_API_KEY=
OPENFACTURA_ENDPOINT=
OPENFACTURA_DTE_TYPE=39
OPENFACTURA_COMPANY_RUT=
OPENFACTURA_COMPANY_NAME="Honda Fest Chile"
